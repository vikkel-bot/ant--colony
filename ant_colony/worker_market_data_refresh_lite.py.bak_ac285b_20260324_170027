import os
import re
import json
import glob
from datetime import datetime, UTC

ANT_OUT = r"C:\Trading\ANT_OUT"
OUT_PATH = os.path.join(ANT_OUT, "worker_market_data.json")

MARKETS = [
    "ADA-EUR",
    "BNB-EUR",
    "BTC-EUR",
    "ETH-EUR",
    "SOL-EUR",
    "XRP-EUR",
]

FILE_PATTERNS = [
    "*_worker_adapter_probe_hook.json",
    "*_worker_adapter_probe_status.json",
    "*_market_data*.json",
    "*_worker_summary.json",
    "*_summary.json",
]


def load_json(path, default=None):
    if not os.path.exists(path):
        return {} if default is None else default
    try:
        with open(path, "r", encoding="utf-8-sig") as f:
            return json.load(f)
    except Exception:
        return {} if default is None else default


def save_json_atomic(path, obj):
    tmp = path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(obj, f, indent=2)
    os.replace(tmp, path)


def to_float(value, default=0.0):
    try:
        return float(value)
    except Exception:
        return float(default)


def market_to_prefix(market):
    return str(market).split("-")[0].lower()


def market_to_upper_prefix(market):
    return str(market).split("-")[0].upper()


def pick(dct, *keys, default=None):
    if not isinstance(dct, dict):
        return default
    for key in keys:
        if key in dct and dct.get(key) is not None:
            return dct.get(key)
    return default


def deep_get(dct, path, default=None):
    cur = dct
    for key in path:
        if not isinstance(cur, dict) or key not in cur:
            return default
        cur = cur[key]
    return cur


def parse_market_from_filename(path):
    name = os.path.basename(path).upper()

    for market in MARKETS:
        if market in name:
            return market

    m = re.match(r"^([A-Z0-9]+)[_\-]", name)
    if m:
        sym = m.group(1)
        candidate = f"{sym}-EUR"
        if candidate in MARKETS:
            return candidate

    return None


def candidate_files():
    seen = set()
    out = []
    for pattern in FILE_PATTERNS:
        for path in glob.glob(os.path.join(ANT_OUT, pattern)):
            if path not in seen and os.path.isfile(path):
                seen.add(path)
                out.append(path)
    return sorted(out)


def extract_price_info(data):
    if not isinstance(data, dict):
        return None

    candidates = [
        ("last_price", pick(data, "last_price")),
        ("close", pick(data, "close")),
        ("price", pick(data, "price")),
        ("mark_price", pick(data, "mark_price")),
        ("market_price", pick(data, "market_price")),
        ("last.close", deep_get(data, ["last", "close"])),
        ("candle.close", deep_get(data, ["candle", "close"])),
        ("last_candle.close", deep_get(data, ["last_candle", "close"])),
        ("last_closed_candle.close", deep_get(data, ["last_closed_candle", "close"])),
        ("probe.last_price", deep_get(data, ["probe", "last_price"])),
        ("probe.close", deep_get(data, ["probe", "close"])),
        ("payload.last_price", deep_get(data, ["payload", "last_price"])),
        ("payload.close", deep_get(data, ["payload", "close"])),
    ]

    for field_name, raw_value in candidates:
        price = to_float(raw_value, 0.0)
        if price > 0.0:
            ts = pick(
                data,
                "ts_utc",
                "ts",
                "timestamp_utc",
                "timestamp",
                default=pick(
                    deep_get(data, ["last"], default={}),
                    "ts_utc",
                    "ts",
                    default=pick(
                        deep_get(data, ["candle"], default={}),
                        "ts_utc",
                        "ts",
                        default=pick(
                            deep_get(data, ["last_candle"], default={}),
                            "ts_utc",
                            "ts",
                            default=pick(
                                deep_get(data, ["last_closed_candle"], default={}),
                                "ts_utc",
                                "ts",
                                default=None
                            )
                        )
                    )
                )
            )
            return {
                "last_price": price,
                "ts_utc": ts,
                "field": field_name
            }

    return None


def main():
    now_utc = datetime.now(UTC).isoformat()

    per_market = {}
    per_market_sources = {}

    files = candidate_files()

    for path in files:
        data = load_json(path, {})
        market = pick(data, "market", default=None)
        if not market:
            market = parse_market_from_filename(path)

        if market not in MARKETS:
            continue

        px = extract_price_info(data)
        if not px:
            continue

        prev = per_market.get(market)
        new_ts = str(px.get("ts_utc") or "")
        prev_ts = str((prev or {}).get("ts_utc") or "")

        replace = False
        if prev is None:
            replace = True
        elif new_ts and prev_ts:
            replace = new_ts >= prev_ts
        elif new_ts and not prev_ts:
            replace = True

        if replace:
            per_market[market] = {
                "market": market,
                "last_price": round(to_float(px.get("last_price", 0.0), 0.0), 8),
                "ts_utc": px.get("ts_utc"),
                "source_file": path,
                "source_field": px.get("field"),
                "source_component": pick(data, "component", default="unknown")
            }
            per_market_sources[market] = os.path.basename(path)

    markets_out = {}
    zero_price_count = 0
    priced_count = 0
    missing_markets = []

    for market in MARKETS:
        row = per_market.get(market)
        if row is None:
            markets_out[market] = {
                "market": market,
                "last_price": 0.0,
                "ts_utc": None,
                "source_file": None,
                "source_field": None,
                "source_component": None,
                "state": "MISSING"
            }
            zero_price_count += 1
            missing_markets.append(market)
            continue

        price = to_float(row.get("last_price", 0.0), 0.0)
        if price > 0.0:
            priced_count += 1
            row["state"] = "OK"
        else:
            zero_price_count += 1
            row["state"] = "ZERO_PRICE"

        markets_out[market] = row

    out = {
        "component": "worker_market_data_refresh_lite",
        "ts_utc": now_utc,
        "market_count": len(MARKETS),
        "priced_count": priced_count,
        "zero_price_count": zero_price_count,
        "missing_markets": missing_markets,
        "markets": markets_out
    }

    save_json_atomic(OUT_PATH, out)
    print(json.dumps(out, indent=2))


if __name__ == "__main__":
    main()

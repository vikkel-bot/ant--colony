import os
import json
import glob
from datetime import datetime, UTC

ANT_OUT = r"C:\Trading\ANT_OUT"

INTENT_PATTERN = os.path.join(ANT_OUT, "*_execution_intent.json")

LOG_FILE = os.path.join(ANT_OUT, "paper_execution_log.jsonl")
POSITIONS_FILE = os.path.join(ANT_OUT, "paper_positions.json")
SUMMARY_FILE = os.path.join(ANT_OUT, "paper_execution_summary.json")
EXECUTED_FILE = os.path.join(ANT_OUT, "paper_executed_ids.json")
PORTFOLIO_FILE = os.path.join(ANT_OUT, "paper_portfolio_state.json")
MARKET_DATA_FILE = os.path.join(ANT_OUT, "worker_market_data.json")
METRICS_FILE = os.path.join(ANT_OUT, "paper_execution_metrics.json")


def load_json(path):
    if not os.path.exists(path):
        return None
    with open(path, "r", encoding="utf-8-sig") as f:
        return json.load(f)


def save_json(path, obj):
    with open(path, "w", encoding="utf-8") as f:
        json.dump(obj, f, indent=2)


def append_jsonl(path, obj):
    with open(path, "a", encoding="utf-8") as f:
        f.write(json.dumps(obj) + "\n")


def load_positions():
    if not os.path.exists(POSITIONS_FILE):
        return {}
    return load_json(POSITIONS_FILE)


def save_positions(p):
    save_json(POSITIONS_FILE, p)


def load_executed_ids():
    if not os.path.exists(EXECUTED_FILE):
        return set()
    with open(EXECUTED_FILE, "r", encoding="utf-8-sig") as f:
        return set(json.load(f))


def save_executed_ids(ids):
    with open(EXECUTED_FILE, "w", encoding="utf-8") as f:
        json.dump(sorted(list(ids)), f, indent=2)


def load_portfolio():
    if not os.path.exists(PORTFOLIO_FILE):
        return {
            "equity": 10000.0,
            "cash": 10000.0,
            "positions": {}
        }
    return load_json(PORTFOLIO_FILE)


def save_portfolio(p):
    save_json(PORTFOLIO_FILE, p)


def load_market_prices():
    if not os.path.exists(MARKET_DATA_FILE):
        return {}

    data = load_json(MARKET_DATA_FILE) or {}
    prices = {}

    for m, info in data.get("markets", {}).items():
        prices[m] = info.get("last_price", 0)

    return prices


def build_metrics(portfolio, positions):
    return {
        "component": "paper_execution_metrics",
        "equity": portfolio.get("equity", 0),
        "cash": portfolio.get("cash", 0),
        "position_count": len(positions),
        "markets": list(positions.keys())
    }


def resolve_price_and_source(market, prices):
    if market in prices:
        return prices.get(market, 0), "worker_market_data.last_price"
    return 0, "fallback_zero"


def to_float(value, default=0.0):
    try:
        return float(value)
    except Exception:
        return float(default)


def calc_candidate_size(action, price, size_mult, portfolio):
    if action != "ENTER_LONG":
        return 0.0, 0.0

    px = to_float(price, 0.0)
    sm = to_float(size_mult, 0.0)
    cash = to_float(portfolio.get("cash", 0.0), 0.0)

    if px <= 0.0 or sm <= 0.0 or cash <= 0.0:
        return 0.0, 0.0

    base_notional = min(1000.0, cash * 0.10)
    notional_eur = base_notional * sm
    size = notional_eur / px

    return round(size, 10), round(notional_eur, 2)


def current_position_state(pos_row):
    if not isinstance(pos_row, dict):
        return "FLAT"
    return str(pos_row.get("position", "FLAT") or "FLAT").upper()


def maybe_open_long_position(positions, portfolio, market, ts, decision_id, execution_id, action, price, size, notional_eur):
    pos = positions.get(market, {
        "market": market,
        "position": "FLAT",
        "size": 0.0
    })

    position_state = current_position_state(pos)
    cash = to_float(portfolio.get("cash", 0.0), 0.0)

    if action == "ENTER_LONG" and position_state == "FLAT" and price > 0 and size > 0 and notional_eur > 0 and cash >= notional_eur:
        positions[market] = {
            "market": market,
            "position": "LONG",
            "size": size,
            "entry_price": price,
            "entry_ts": ts,
            "decision_id": decision_id,
            "execution_id": execution_id
        }

        portfolio["cash"] = round(cash - notional_eur, 2)
        portfolio_positions = portfolio.get("positions", {}) or {}
        portfolio_positions[market] = {
            "position": "LONG",
            "size": size,
            "entry_price": price,
            "entry_ts": ts,
            "decision_id": decision_id,
            "execution_id": execution_id,
            "notional_eur": notional_eur
        }
        portfolio["positions"] = portfolio_positions
        portfolio["equity"] = round(to_float(portfolio.get("cash", 0.0), 0.0) + sum(
            to_float(v.get("size", 0.0), 0.0) * to_float(v.get("entry_price", 0.0), 0.0)
            for v in portfolio_positions.values()
        ), 2)
        return True

    return False


def run():

    ts = datetime.now(UTC).isoformat()

    positions = load_positions()
    executed_ids = load_executed_ids()
    portfolio = load_portfolio()
    prices = load_market_prices()

    intents = glob.glob(INTENT_PATTERN)

    processed = 0
    allowed = 0
    skipped = 0

    for path in intents:

        intent = load_json(path)
        if not intent:
            continue

        market = intent.get("market")
        cycle_id = intent.get("cycle_id")
        decision_id = intent.get("decision_id")
        action = intent.get("action", "NO_ACTION")
        strategy = intent.get("strategy", "NONE")
        bias = intent.get("bias", "NEUTRAL")
        size_mult = intent.get("size_mult", 0)
        execution_allowed = bool(intent.get("execution_allowed", False))
        block_reason = intent.get("block_reason")
        execution_readiness = intent.get("execution_readiness", {})
        readiness_reason = execution_readiness.get("reason")

        processed += 1

        if not execution_allowed:
            skipped += 1
            continue

        execution_id = f"{market}_{cycle_id}"

        if execution_id in executed_ids:
            skipped += 1
            continue

        allowed += 1
        executed_ids.add(execution_id)

        price, price_source = resolve_price_and_source(market, prices)
        size, notional_eur = calc_candidate_size(action, price, size_mult, portfolio)

        position_opened = maybe_open_long_position(
            positions=positions,
            portfolio=portfolio,
            market=market,
            ts=ts,
            decision_id=decision_id,
            execution_id=execution_id,
            action=action,
            price=price,
            size=size,
            notional_eur=notional_eur
        )

        log_event = {
            "ts": ts,
            "market": market,
            "cycle_id": cycle_id,
            "decision_id": decision_id,
            "execution_id": execution_id,
            "event": "PAPER_FILL_CANDIDATE",
            "action": action,
            "strategy": strategy,
            "bias": bias,
            "size_mult": size_mult,
            "price": price,
            "price_source": price_source,
            "size": size,
            "notional_eur": notional_eur,
            "position_opened": position_opened,
            "block_reason": block_reason,
            "readiness_reason": readiness_reason
        }

        append_jsonl(LOG_FILE, log_event)

        if market not in positions:
            positions[market] = {
                "market": market,
                "position": "FLAT",
                "size": 0.0
            }

    save_positions(positions)
    save_executed_ids(executed_ids)
    save_portfolio(portfolio)

    metrics = build_metrics(portfolio, positions)
    save_json(METRICS_FILE, metrics)

    summary = {
        "component": "paper_execution_runner_lite",
        "ts": ts,
        "intents_processed": processed,
        "intents_allowed": allowed,
        "intents_skipped": skipped,
        "log_file_exists": os.path.exists(LOG_FILE),
        "executed_ids_count": len(executed_ids),
        "position_count": len(positions)
    }

    save_json(SUMMARY_FILE, summary)

    print(json.dumps(summary, indent=2))


if __name__ == "__main__":
    run()

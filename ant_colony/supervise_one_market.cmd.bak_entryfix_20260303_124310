@echo off
setlocal EnableExtensions EnableDelayedExpansion

REM Usage: supervise_one_market.cmd BTC-EUR
set "MARKET=%~1"
if "%MARKET%"=="" (
  echo ERROR: missing MARKET. Example: supervise_one_market.cmd BTC-EUR
  exit /b 2
)

REM Repo root is parent of this script dir
set "SCRIPTDIR=%~dp0"
for %%I in ("%SCRIPTDIR%..") do set "REPOROOT=%%~fI"

set "OUTDIR=C:\Trading\ANT_OUT"
if not exist "%OUTDIR%" mkdir "%OUTDIR%" >nul 2>&1

set "LOG=%OUTDIR%\worker_%MARKET%.log"

REM Restart backoff settings
set "BASE_S=2"
set "MAX_S=60"
set "SLEEP_S=%BASE_S%"

:restart
echo ==== START %DATE% %TIME% market=%MARKET% ====>> "%LOG%"

REM Heartbeat START
powershell -NoProfile -ExecutionPolicy Bypass -Command ^
  "$o=@{ts_utc=(Get-Date).ToUniversalTime().ToString('o'); market='%MARKET%'; state='starting'}; $p=Join-Path '%OUTDIR%' ('hb_%MARKET%.json'); ($o | ConvertTo-Json -Compress) | Set-Content -Path $p -Encoding Ascii"

REM Run worker (use python from PATH)
pushd "%REPOROOT%\ant_colony\workers\%MARKET%"
python worker.py >> "%LOG%" 2>&1
set "EC=%ERRORLEVEL%"
popd

echo ==== EXIT %DATE% %TIME% market=%MARKET% ec=%EC% ====>> "%LOG%"

REM Heartbeat EXIT
powershell -NoProfile -ExecutionPolicy Bypass -Command ^
  "$o=@{ts_utc=(Get-Date).ToUniversalTime().ToString('o'); market='%MARKET%'; state='exited'; exit_code=%EC%}; $p=Join-Path '%OUTDIR%' ('hb_%MARKET%.json'); ($o | ConvertTo-Json -Compress) | Set-Content -Path $p -Encoding Ascii"

REM Backoff then restart
if %SLEEP_S% LSS %MAX_S% (
  set /a SLEEP_S=SLEEP_S*2
  if !SLEEP_S! GTR %MAX_S% set "SLEEP_S=%MAX_S%"
)

timeout /t %SLEEP_S% /nobreak >nul
goto restart
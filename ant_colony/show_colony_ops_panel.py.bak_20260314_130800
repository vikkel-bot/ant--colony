from pathlib import Path


VERSION = "show_colony_ops_panel_v7"
SUPERVISOR_STATUS = Path(r"C:\Trading\ANT_OUT\colony_supervisor_status_lite.json")
RECOVERY_STATUS = Path(r"C:\Trading\ANT_OUT\colony_supervisor_status_lite.json")
PRIMARY_DASHBOARD_PATH = Path(r"C:\Trading\ANT_OUT\combined_colony_status.tsv")
FALLBACK_DASHBOARD_PATH = Path(r"C:\Trading\ANT_OUT\colony_status.tsv")

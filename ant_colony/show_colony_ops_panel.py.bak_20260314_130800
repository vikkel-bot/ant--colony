def print_colony_table():
    rows, source_path, source_kind = load_market_rows()

    print_header("COLONY MARKETS")

    if not rows:
        print("market_snapshot_source : MISSING")
        print("market_snapshot_state  : MISSING")
        print("market_snapshot_reason : NO_COLONY_STATUS_ROWS")
        print("")
        print("no colony status rows")
        return

    latest_ts = str(rows[0].get("ts_utc", "") or "")
    snapshot_age_seconds = calc_age_seconds(latest_ts)
    snapshot_is_stale = (snapshot_age_seconds < 0) or (snapshot_age_seconds > MARKET_STATUS_MAX_AGE_SECONDS)
    snapshot_state = "STALE" if snapshot_is_stale else "FRESH"
    snapshot_reason = "MARKET_STATUS_STALE" if snapshot_is_stale else "MARKET_STATUS_FRESH"

    print(f"market_snapshot_source : {source_kind}")
    print(f"market_snapshot_path   : {source_path}")
    print(f"market_snapshot_state  : {snapshot_state}")
    print(f"market_snapshot_reason : {snapshot_reason}")
    print(f"market_snapshot_ts     : {latest_ts}")
    print(f"market_snapshot_age_s  : {snapshot_age_seconds}")
    print("")

    if snapshot_is_stale:
        print("stale market snapshot detected")
        print("market rows suppressed")
        return

    headers = list(rows[0].keys())
    print(" ".join(h.ljust(12) for h in headers))

    for r in rows:
        print(" ".join(str(r.get(h, "")).ljust(12) for h in headers))


def print_strategy_ops_table():
    selection_doc = read_json(SELECTION_PATH)
    execution_doc = read_json(EXECUTION_PATH)
    registry = load_worker_registry()

    selection_markets = normalize_markets_block(selection_doc)
    execution_markets = normalize_markets_block(execution_doc)
    all_markets = sorted(set(selection_markets.keys()) | set(execution_markets.keys()))

    print_header("COLONY STRATEGY OPS")

    if not all_markets:
        print("strategy_ops_state : MISSING")
        print("strategy_ops_reason: NO_SELECTION_OR_EXECUTION_ROWS")
        return

    headers = [
        ("market", 10),
        ("strategy", 8),
        ("family", 8),
        ("class", 16),
        ("prio", 5),
        ("bucket", 10),
        ("cooldown", 10),
        ("sel_bias", 8),
        ("sel_size", 8),
        ("exec_mode", 16),
        ("exec_bias", 9),
        ("exec_size", 9),
    ]

    print(" ".join(pad(h, w) for h, w in headers))
    print(" ".join("-" * w for _, w in headers))

    for market in all_markets:
        srow = selection_markets.get(market, {}) or {}
        erow = execution_markets.get(market, {}) or {}

        strategy = str(srow.get("selected_strategy", erow.get("selected_strategy", "NONE")) or "NONE").upper()
        meta = registry.get(strategy) or registry.get("NONE") or {}

        values = [
            market,
            strategy,
            srow.get("strategy_family", erow.get("strategy_family", "")),
            srow.get("strategy_class", erow.get("strategy_class", "")),
            srow.get("strategy_priority", erow.get("strategy_priority", "")),
            meta.get("capital_bucket", ""),
            meta.get("cooldown_policy", ""),
            srow.get("selected_bias", ""),
            srow.get("selected_size_mult", ""),
            erow.get("execution_mode", ""),
            erow.get("execution_bias", ""),
            erow.get("execution_size_mult", ""),
        ]

        print(" ".join(pad(v, w) for v, (_, w) in zip(values, headers)))

    print("")



MARKET_STATUS_MAX_AGE_SECONDS = 300
RECOVERY_STATUS_MAX_AGE_SECONDS = 300


def read_json(path):
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


def read_tsv(path):
    if not path.exists():
        return []

    text = path.read_text(encoding="utf-8-sig")
    lines = text.splitlines()
    if len(lines) < 2:
        return []

    headers = [h.strip() for h in lines[0].split("\t")]
    rows = []

    for line in lines[1:]:
        if not line.strip():
            continue
        parts = [p.strip() for p in line.split("\t")]
        row = dict(zip(headers, parts))
        rows.append(row)

    return rows


def normalize_markets_block(doc):
    markets = doc.get("markets", {}) or {}

    if isinstance(markets, dict):
        return {str(k): v for k, v in markets.items() if isinstance(v, dict)}

    out = {}
    if isinstance(markets, list):
        for row in markets:
            if not isinstance(row, dict):
                continue
            market = str(row.get("market", "") or "")
            if not market:
                continue
            out[market] = row
    return out


def load_worker_registry():
    doc = read_json(REGISTRY_PATH)
    strategies = doc.get("strategies", {}) or {}
    out = {}

    for k, v in strategies.items():
        key = str(k or "").upper()
        if not key or not isinstance(v, dict):
            continue
        out[key] = v

    if "NONE" not in out:
        out["NONE"] = {
            "family": "NONE",
            "class": "INACTIVE",
            "priority": 0,
            "capital_bucket": "INACTIVE",
            "cooldown_policy": "NONE",
        }

    return out


def parse_iso_z(value):
    if not value:
        return None
    try:
        return datetime.fromisoformat(str(value).replace("Z", "+00:00"))
    except Exception:
        return None


def calc_age_seconds(ts_value):
    ts_dt = parse_iso_z(ts_value)
    if ts_dt is None:
        return -1
    return int((datetime.now(timezone.utc) - ts_dt).total_seconds())


def print_header(title):
    print("")
    print("=" * 80)
    print(title)
    print("=" * 80)
    print("")


def pad(v, w):
    s = str(v)
    return s[:w].ljust(w)


def load_market_rows():
    primary_rows = read_tsv(PRIMARY_DASHBOARD_PATH)
    if primary_rows:
        return primary_rows, str(PRIMARY_DASHBOARD_PATH), "PRIMARY"

    fallback_rows = read_tsv(FALLBACK_DASHBOARD_PATH)
    if fallback_rows:
        return fallback_rows, str(FALLBACK_DASHBOARD_PATH), "FALLBACK"

    return [], "", "MISSING"


def get_market_snapshot_health():
    rows, source_path, source_kind = load_market_rows()

    if not rows:
        return {
            "source": source_kind,
            "path": source_path,
            "state": "MISSING",
            "reason": "NO_COLONY_STATUS_ROWS",
            "ts": "",
            "age_s": -1,
            "is_stale": True,
        }

    latest_ts = str(rows[0].get("ts_utc", "") or "")
    snapshot_age_seconds = calc_age_seconds(latest_ts)
    snapshot_is_stale = (snapshot_age_seconds < 0) or (snapshot_age_seconds > MARKET_STATUS_MAX_AGE_SECONDS)
    snapshot_state = "STALE" if snapshot_is_stale else "FRESH"
    snapshot_reason = "MARKET_STATUS_STALE" if snapshot_is_stale else "MARKET_STATUS_FRESH"

    return {
        "source": source_kind,
        "path": source_path,
        "state": snapshot_state,
        "reason": snapshot_reason,
        "ts": latest_ts,
        "age_s": snapshot_age_seconds,
        "is_stale": snapshot_is_stale,
    }


def get_supervisor_health():
    s = read_json(SUPERVISOR_STATUS)
    state = str(s.get("supervisor_state", "") or "").upper()
    runtime_state = str(s.get("watchdog_runtime_state", "") or "").upper()

    if state == "OK" and runtime_state in ("RUNNING_OK", "FRESH", ""):
        health = "OK"
        reason = "SUPERVISOR_RUNNING_OK"
    elif state:
        health = "DEGRADED"
        reason = f"SUPERVISOR_STATE_{state}"
    else:
        health = "MISSING"
        reason = "NO_SUPERVISOR_STATUS"

    return {
        "health": health,
        "reason": reason,
        "state": state,
        "runtime_state": runtime_state,
    }


def get_strategy_pipeline_health():
    selection_doc = read_json(SELECTION_PATH)
    execution_doc = read_json(EXECUTION_PATH)

    selection_markets = normalize_markets_block(selection_doc)
    execution_markets = normalize_markets_block(execution_doc)

    if not selection_markets and not execution_markets:
        return {
            "health": "MISSING",
            "reason": "NO_SELECTION_OR_EXECUTION_ROWS",
            "markets": 0,
        }

    if selection_markets and execution_markets:
        return {
            "health": "OK",
            "reason": "SELECTION_AND_EXECUTION_PRESENT",
            "markets": len(set(selection_markets.keys()) | set(execution_markets.keys())),
        }

    return {
        "health": "DEGRADED",
        "reason": "PARTIAL_PIPELINE_OUTPUT",
        "markets": len(set(selection_markets.keys()) | set(execution_markets.keys())),
    }


def print_health_summary():
    supervisor = get_supervisor_health()
    market = get_market_snapshot_health()
    pipeline = get_strategy_pipeline_health()

    components = [
        supervisor.get("health", "MISSING"),
        market.get("state", "MISSING"),
        pipeline.get("health", "MISSING"),
    ]

    if "MISSING" in components:
        overall = "MISSING"
    elif "STALE" in components or "DEGRADED" in components:
        overall = "DEGRADED"
    else:
        overall = "OK"

    print_header("COLONY HEALTH")

    print(f"supervisor_health        : {supervisor.get('health','')}")
    print(f"supervisor_reason        : {supervisor.get('reason','')}")
    print(f"market_data_health       : {market.get('state','')}")
    print(f"market_data_reason       : {market.get('reason','')}")
    print(f"strategy_pipeline_health : {pipeline.get('health','')}")
    print(f"strategy_pipeline_reason : {pipeline.get('reason','')}")
    print(f"strategy_pipeline_markets: {pipeline.get('markets','')}")
    print(f"overall_health           : {overall}")



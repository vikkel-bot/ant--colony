import json
from pathlib import Path


OUT_DIR = Path(r"C:\Trading\ANT_OUT")

COMBINED_STATUS = OUT_DIR / "combined_colony_status.json"
ALLOC_TARGETS = OUT_DIR / "alloc_targets.json"
RISK_TARGETS = OUT_DIR / "colony_risk_targets.json"
MARKET_HEALTH = OUT_DIR / "market_health.json"
WORKER_SELECTION = OUT_DIR / "worker_strategy_selection.json"
WORKER_EXEC_PLAN = OUT_DIR / "worker_execution_plan.json"


def load_json(path: Path):
    if not path.exists():
        return {}, f"missing:{path.name}"

    encodings = ["utf-8-sig", "utf-8"]
    last_error = None

    for enc in encodings:
        try:
            text = path.read_text(encoding=enc)
            return json.loads(text), None
        except Exception as e:
            last_error = e

    return {}, f"read_error:{path.name}:{last_error}"


def get_markets(doc):
    if isinstance(doc, dict):
        markets = doc.get("markets", {})
        if isinstance(markets, dict):
            return markets
    return {}


def text(v):
    if v is None:
        return ""
    return str(v)


def pad(v, width):
    s = text(v)
    if len(s) >= width:
        return s[:width]
    return s + (" " * (width - len(s)))


def main():
    combined_doc, combined_err = load_json(COMBINED_STATUS)
    alloc_doc, alloc_err = load_json(ALLOC_TARGETS)
    risk_doc, risk_err = load_json(RISK_TARGETS)
    health_doc, health_err = load_json(MARKET_HEALTH)
    selection_doc, selection_err = load_json(WORKER_SELECTION)
    exec_doc, exec_err = load_json(WORKER_EXEC_PLAN)

    combined_markets = get_markets(combined_doc)
    alloc_markets = get_markets(alloc_doc)
    risk_markets = get_markets(risk_doc)
    health_markets = get_markets(health_doc)
    selection_markets = get_markets(selection_doc)
    exec_markets = get_markets(exec_doc)

    all_markets = sorted(
        set(combined_markets.keys()) |
        set(alloc_markets.keys()) |
        set(risk_markets.keys()) |
        set(health_markets.keys()) |
        set(selection_markets.keys()) |
        set(exec_markets.keys())
    )

    ts_utc = (
        exec_doc.get("ts_utc", "") or
        selection_doc.get("ts_utc", "") or
        combined_doc.get("ts_utc", "") or
        risk_doc.get("ts_utc", "") or
        health_doc.get("ts_utc", "") or
        alloc_doc.get("ts_utc", "")
    )

    print("")
    print("UNIFIED ANT COLONY DASHBOARD")
    print(f"ts_utc={ts_utc} markets={len(all_markets)}")
    print("")

    headers = [
        ("market", 10),
        ("trend", 9),
        ("e3", 6),
        ("e4", 4),
        ("alloc", 6),
        ("risk", 6),
        ("health", 6),
        ("final", 6),
        ("sel_strat", 9),
        ("sel_bias", 8),
        ("sel_size", 8),
        ("exec_on", 7),
        ("exec_bias", 9),
        ("exec_size", 9),
        ("exec_mode", 15),
        ("reason", 64),
    ]

    print(" ".join(pad(name, width) for name, width in headers))
    print(" ".join("-" * width for _, width in headers))

    for market in all_markets:
        combined_row = combined_markets.get(market, {}) or {}
        edge3_row = combined_row.get("edge3", {}) or {}
        edge4_row = combined_row.get("edge4", {}) or {}

        alloc_row = alloc_markets.get(market, {}) or {}
        risk_row = risk_markets.get(market, {}) or {}
        health_row = health_markets.get(market, {}) or {}
        selection_row = selection_markets.get(market, {}) or {}
        exec_row = exec_markets.get(market, {}) or {}

        trend = edge3_row.get("cb20_trend", "")
        e3 = edge3_row.get("gate", "")
        e4 = edge4_row.get("state", "")

        alloc_mult = alloc_row.get("target_size_mult", "")
        risk_mult = risk_row.get("target_size_mult", "")
        health_mult = health_row.get("health_size_mult", "")
        final_mult = risk_row.get("target_size_mult", "")

        sel_strat = selection_row.get("selected_strategy", "")
        sel_bias = selection_row.get("selected_bias", "")
        sel_size = selection_row.get("selected_size_mult", "")

        exec_on = exec_row.get("enabled", "")
        exec_bias = exec_row.get("execution_bias", "")
        exec_size = exec_row.get("execution_size_mult", "")
        exec_mode = exec_row.get("execution_mode", "")

        reason = exec_row.get("plan_reason", "") or selection_row.get("selection_reason", "") or risk_row.get("reason", "")

        values = [
            market,
            trend,
            e3,
            e4,
            alloc_mult,
            risk_mult,
            health_mult,
            final_mult,
            sel_strat,
            sel_bias,
            sel_size,
            exec_on,
            exec_bias,
            exec_size,
            exec_mode,
            reason,
        ]

        print(" ".join(pad(v, w) for v, (_, w) in zip(values, headers)))

    print("")
    print("SOURCES")
    print(f"combined_status  = {COMBINED_STATUS}")
    print(f"alloc_targets    = {ALLOC_TARGETS}")
    print(f"risk_targets     = {RISK_TARGETS}")
    print(f"market_health    = {MARKET_HEALTH}")
    print(f"worker_selection = {WORKER_SELECTION}")
    print(f"worker_exec_plan = {WORKER_EXEC_PLAN}")
    print(f"combined_error   = {combined_err}")
    print(f"alloc_error      = {alloc_err}")
    print(f"risk_error       = {risk_err}")
    print(f"health_error     = {health_err}")
    print(f"selection_error  = {selection_err}")
    print(f"exec_error       = {exec_err}")
    print("")


if __name__ == "__main__":
    main()
@echo off
setlocal EnableExtensions EnableDelayedExpansion

set "MARKET=%~1"
if "%MARKET%"=="" exit /b 2

set "SCRIPTDIR=%~dp0"
for %%I in ("%SCRIPTDIR%..") do set "REPOROOT=%%~fI"

set "OUTDIR=C:\Trading\ANT_OUT"
if not exist "%OUTDIR%" mkdir "%OUTDIR%" >nul 2>&1
set "LOG=%OUTDIR%\worker_%MARKET%.log"

set "BASE_S=2"
set "MAX_S=60"
set "SLEEP_S=%BASE_S%"

set "W=%REPOROOT%\ant_colony\workers\%MARKET%"

REM Find entry script (preferred list)
set "ENTRY="
for %%F in (worker.py run_worker.py worker_main.py main.py run.py bot.py) do (
  if exist "%W%\%%F" if "!ENTRY!"=="" set "ENTRY=%%F"
)

REM Fallback: first *.py except edge3_fetch_cache.py
if "%ENTRY%"=="" (
  for /f "delims=" %%F in ('dir /b "%W%\*.py" 2^>nul') do (
    if /I not "%%F"=="edge3_fetch_cache.py" if "!ENTRY!"=="" set "ENTRY=%%F"
  )
)

if "%ENTRY%"=="" (
  echo ==== ERROR %DATE% %TIME% market=%MARKET% no *.py found in %W% ====>> "%LOG%"
  exit /b 3
)

:restart
echo ==== START %DATE% %TIME% market=%MARKET% entry=%ENTRY% ====>> "%LOG%"

powershell -NoProfile -ExecutionPolicy Bypass -Command ^
  "$o=@{ts_utc=(Get-Date).ToUniversalTime().ToString('o'); market='%MARKET%'; state='starting'; entry='%ENTRY%'}; $p=Join-Path '%OUTDIR%' ('hb_%MARKET%.json'); ($o | ConvertTo-Json -Compress) | Set-Content -Path $p -Encoding Ascii"

pushd "%W%"
python "%ENTRY%" >> "%LOG%" 2>&1
set "EC=%ERRORLEVEL%"
popd

echo ==== EXIT %DATE% %TIME% market=%MARKET% ec=%EC% entry=%ENTRY% ====>> "%LOG%"

powershell -NoProfile -ExecutionPolicy Bypass -Command ^
  "$o=@{ts_utc=(Get-Date).ToUniversalTime().ToString('o'); market='%MARKET%'; state='exited'; exit_code=%EC%; entry='%ENTRY%'}; $p=Join-Path '%OUTDIR%' ('hb_%MARKET%.json'); ($o | ConvertTo-Json -Compress) | Set-Content -Path $p -Encoding Ascii"

if %SLEEP_S% LSS %MAX_S% (
  set /a SLEEP_S=SLEEP_S*2
  if !SLEEP_S! GTR %MAX_S% set "SLEEP_S=%MAX_S%"
)

timeout /t %SLEEP_S% /nobreak >nul
goto restart